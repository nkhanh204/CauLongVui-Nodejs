{
  "info": {
    "name": "CauLongVui API",
    "description": "Complete API Collection for CauLongVui Backend — 34 endpoints across 9 modules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "courtId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "slotId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "voucherId", "value": "" },
    { "key": "reviewId", "value": "" },
    { "key": "roleId", "value": "" }
  ],
  "item": [
    {
      "name": "01. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van A\",\n  \"phoneNumber\": \"0912345678\",\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\",\n  \"roleId\": \"{{roleId}}\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('userId', res.data.user?.id || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"0912345678\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
